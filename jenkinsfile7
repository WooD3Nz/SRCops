pipeline {
    agent any
    stages {
        stage('clear workspace') {
            steps {
                cleanWs()
            }
        }
        stage('checkout SCM') {
            steps {
                git branch: 'main', credentialsId: 'admin', url: 'https://github.com/WooD3Nz/SRCops.git'
            }
        }
        stage('docker create apache container') {
            steps {
                sh '''
                    docker stop contapache01 && docker rm -f contapache01
                    docker run -d --name contapache01 --hostname contapache01 -v volumecontapache01:/var/www/html --network macvlan192 --ip 192.168.10.20 mon-apache2:latest
                    docker ps
                    docker exec contapache01 /etc/init.d/apache2 start
                '''
            }
        }
        stage('copy-fichiers-mysite') {
            steps {
                sh '''
                    docker cp ./mysite/. contapache01:/var/www/html/
                    docker exec contapache01 ls -la /var/www/html
                '''
            }
        }
    }
}
